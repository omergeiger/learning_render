# WhatsApp Business API Configuration
# Get these from: https://developers.facebook.com/apps

# Your WhatsApp Business phone number ID
META_WA_PHONE_ID=your_phone_number_id_here

# Access token from Meta Developer Console
META_WA_ACCESS_TOKEN=your_access_token_here

# Webhook verification token (you create this - must match Meta Console)
META_WA_VERIFY_TOKEN=your_verify_token_here

# Server Configuration (optional - Render sets PORT automatically)
# PORT=5000
